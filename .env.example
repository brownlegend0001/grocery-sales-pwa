# Copy to ".env" and fill in. Vite only exposes vars prefixed with VITE_.
# None of these are secrets — the Apps Script URL points at your Web App and the
# Google client id is public by design. Access is enforced server-side by
# verifying the signed Google ID token against VITE_ALLOWED_EMAIL.

# The /exec URL from your Apps Script "Web app" deployment
VITE_SHEETS_API=https://script.google.com/macros/s/XXXXXXXX/exec

# Google Sign-In: OAuth 2.0 "Web application" client id (Google Cloud Console).
# Must match GOOGLE_CLIENT_ID in apps-script/Code.gs.
VITE_GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com

# The only account allowed to use the app. Must match ALLOWED_EMAIL in Code.gs.
VITE_ALLOWED_EMAIL=brownlegend0001@gmail.com

# The data year (matches your sheet tabs)
VITE_YEAR=2026
